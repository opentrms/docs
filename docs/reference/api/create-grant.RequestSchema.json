{"title":"Body","body":{"content":{"application/json":{"schema":{"type":"object","default":null,"description":"Create a data entitlement grant","properties":{"principalType":{"type":"string","default":"","description":"Grant principal type","enum":["USER","GROUP"],"minLength":1,"pattern":"USER|GROUP"},"principalId":{"type":"string","format":"uuid","default":"","description":"Registry user UUID or DATA group UUID"},"dimension":{"type":"string","default":"","description":"Entitlement dimension","enum":["BOOK","LEGAL_ENTITY","COUNTERPARTY","INSTRUMENT"],"minLength":1,"pattern":"BOOK|LEGAL_ENTITY|COUNTERPARTY|INSTRUMENT"},"resourceId":{"type":"string","format":"uuid","default":"","description":"Referenced book/legal-entity/counterparty/instrument UUID; null when wildcard=true"},"wildcard":{"type":"boolean","default":false,"description":"True to grant against the full current dimension set"},"access":{"type":"string","default":"","description":"Access level","enum":["READ","WRITE"],"minLength":1,"pattern":"READ|WRITE"},"effect":{"type":"string","default":"ALLOW","description":"ALLOW (additive, Phase 1 default) or DENY (subtractive restricted-list entry, DS T10)","enum":["ALLOW","DENY"],"pattern":"ALLOW|DENY"},"validFrom":{"type":"string","format":"date-time","default":"","description":"Validity start timestamp"},"validUntil":{"type":"string","format":"date-time","default":"","description":"Validity end timestamp; required for USER grants"},"reason":{"type":"string","default":"","description":"Human-readable reason; required for USER grants","maxLength":2000,"minLength":0}},"required":["access","dimension","principalId","principalType","validFrom"],"title":"CreateDataEntitlementGrantRequestDto"}}},"required":true}}